{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mithril",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#e879f9",
    "dark": "#8b5cf6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Clients & SDKs",
            "pages": [
              "sdks/python",
              "sdks/mcp"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/conventions",
              "concepts/idempotency",
              "concepts/errors",
              "concepts/rate-limits"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/accounts",
              "guides/market-data",
              "guides/guardrails",
              "guides/orders",
              "guides/smart-execution",
              "guides/risk"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api-reference/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API explorer",
          "href": "https://api.trymithril.com/docs",
          "icon": "code"
        },
        {
          "anchor": "Dashboard",
          "href": "https://app.trymithril.com",
          "icon": "gauge"
        },
        {
          "anchor": "Book a call",
          "href": "https://calendly.com/thekarlg",
          "icon": "phone"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Book a call",
        "href": "https://calendly.com/thekarlg"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get beta access",
      "href": "https://app.trymithril.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://trymithril.com",
      "github": "https://github.com/mithril"
    }
  }
}
